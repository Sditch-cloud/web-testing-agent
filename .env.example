# OpenAI API key for NL→DSL compilation
OPENAI_API_KEY=sk-...

# OpenAI base URL for API requests (default: https://api.openai.com)
OPENAI_BASE_URL=https://xxxx

# OpenAI model to use for test case compilation (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# Directory for DSL snapshots and session state
STORAGE_DIR=./data

# Global timeout for a single test case execution (ms, default: 120000)
TEST_EXECUTION_TIMEOUT_MS=120000

# Max retries per step (default: 3)
MAX_STEP_RETRIES=3

# Max token budget for NL→DSL compilation (default: 4096)
COMPILE_MAX_TOKENS=4096

# Optional proxy URL for OpenAI API requests (e.g., http://proxyserver:port)
PROXY_URL=http://xxxx:xxxx